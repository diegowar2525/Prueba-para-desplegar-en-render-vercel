{
	"info": {
		"_postman_id": "7f8b9e62-df21-4f11-9a74-2978a3c8e546",
		"name": "Practica User CRUD & Auth API",
		"description": "Colección de Postman para probar el backend de la práctica (Express, Mongoose, JWT, Google OAuth).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Autenticación",
			"item": [
				{
					"name": "Registrar Usuario Local",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Administrador Inicial\",\n    \"email\": \"admin@portal.com\",\n    \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"register"
							]
						},
						"description": "Crea una nueva cuenta local en el sistema."
					},
					"response": []
				},
				{
					"name": "Iniciar Sesión Local",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.success && jsonData.data.token) {",
									"        pm.globals.set(\"jwt_token\", jsonData.data.token);",
									"        console.log(\"Token guardado automáticamente en variable global: jwt_token\");",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@portal.com\",\n    \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Inicia sesión con credenciales locales y devuelve un JWT."
					},
					"response": []
				},
				{
					"name": "Obtener Perfil Actual (Me)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/auth/me",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"me"
							]
						},
						"description": "Obtiene los detalles del usuario actual a partir del token JWT proporcionado."
					},
					"response": []
				}
			]
		},
		{
			"name": "Usuarios (CRUD)",
			"item": [
				{
