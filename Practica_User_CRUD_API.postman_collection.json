					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/users",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users"
							]
						},
						"description": "Obtiene la lista de todos los usuarios registrados (excluyendo contraseñas). Requiere token JWT en headers."
					},
					"response": []
				},
				{
					"name": "Obtener Usuario por ID",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/users/REPLACE_WITH_USER_ID",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users",
								"REPLACE_WITH_USER_ID"
							]
						},
						"description": "Obtiene detalles de un único usuario mediante su ID. Reemplazar 'REPLACE_WITH_USER_ID' con un ID real obtenido en el listado."
					},
					"response": []
				},
				{
					"name": "Crear Usuario",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Usuario de Prueba\",\n    \"email\": \"prueba@portal.com\",\n    \"password\": \"secreto123\",\n    \"role\": \"user\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users"
							]
						},
						"description": "Crea un nuevo usuario directamente desde el panel de administración (Requiere JWT)."
					},
					"response": []
				},
				{
					"name": "Actualizar Usuario",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Usuario Modificado\",\n    \"email\": \"prueba_actualizado@portal.com\",\n    \"role\": \"admin\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users/REPLACE_WITH_USER_ID",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users",
								"REPLACE_WITH_USER_ID"
							]
						},
						"description": "Actualiza la información de un usuario existente. Reemplazar 'REPLACE_WITH_USER_ID' con un ID real."
					},
					"response": []
				},
				{
					"name": "Eliminar Usuario",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/users/REPLACE_WITH_USER_ID",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users",
								"REPLACE_WITH_USER_ID"
							]
						},
						"description": "Elimina permanentemente a un usuario del sistema mediante su ID."
					},
					"response": []
				}
			]
		}
